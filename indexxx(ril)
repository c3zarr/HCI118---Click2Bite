<footer>
<p>© 2026 Click2Bite - WMSU</p>
</footer>

<!-- LOGIN MODAL -->

<div class="modal" id="loginModal">
<a href="#" class="modal-overlay"></a>

<div class="modal-content">

<a href="#" class="modal-close">
<i class="fas fa-times"></i>
</a>

<div class="modal-header">
<div class="modal-logo">
<i class="fas fa-utensils"></i> Click2Bite
</div>

<h2>Welcome Back</h2>
<p>Log in using your WMSU email</p>
</div>

<form action="homepage.html">

<div class="form-group">
<label><i class="fas fa-envelope"></i> Email</label>
<input 
type="email" 
required
pattern="^[a-zA-Z0-9._%+-]+@wmsu\.edu\.ph$"
title="Use your WMSU email (example@wmsu.edu.ph)">
</div>

<div class="form-group">
<label><i class="fas fa-lock"></i> Password</label>
<input type="password" required>
</div>

<button type="submit" class="btn-login-submit">
Log In
</button>

</form>

<div class="modal-footer">
<p>
Don't have an account?
<a href="#registerModal">Register here</a>
</p>
</div>

</div>
</div>

<!-- REGISTER MODAL -->

<div class="modal" id="registerModal">
<a href="#" class="modal-overlay"></a>

<div class="modal-content">

<a href="#" class="modal-close">
<i class="fas fa-times"></i>
</a>

<div class="modal-header">
<div class="modal-logo">
<i class="fas fa-utensils"></i> Click2Bite
</div>

<h2>Create Account</h2>
<p>Register using WMSU email</p>
</div>

<form action="homepage.html">

<div class="form-group">
<label><i class="fas fa-user"></i>First Name</label>
<input type="text" required>
</div>

<div class="form-group">
<label><i class="fas fa-user"></i> Last Name</label>
<input type="text" required>
</div>

<div class="form-group">
<label><i class="fas fa-envelope"></i> Email</label>
<input 
type="email" required pattern="^[a-zA-Z0-9._%+-]+@wmsu\.edu\.ph$" title="Use your WMSU email (example@wmsu.edu.ph)">
</div>

<div class="form-group">
<label><i class="fas fa-lock"></i> Password</label>
<input type="password" required>
</div>

<div class="form-group">
<label>User Type</label>
<select id="userType" required>
<option value="">Select type</option>
<option value="student">Student</option>
<option value="staff">Staff</option>
<option value="guest">Guest</option>
</select>
</div>

<button type="submit" class="btn-login-submit">
Register
</button>

</form>

<div class="modal-footer">
<p>
Already have an account?
<a href="#loginModal">Log In here</a>
</p>
</div>

</div>
</div>

<script>
document.getElementById("registerForm").addEventListener("submit", function(e){
e.preventDefault();

let name = document.getElementById("name").value;
let email = document.getElementById("email").value;
let password = document.getElementById("pass").value;
let role = document.getElementById("role").value; // admin/vendor/cashier/customer
let type = document.getElementById("userType").value; // student/staff/guest

if(type === ""){
alert("Please select user type");
return;
}

// RULE: Only student/staff must use WMSU email
if((type === "student" || type === "staff") && !email.endsWith("@wmsu.edu.ph")){
alert("Student/Staff must use WMSU email");
return;
}

// Guest can use any email
let user = {
name: name,
email: email,
password: password,
role: role,
type: type
};

localStorage.setItem("user_" + email, JSON.stringify(user));

alert("Registered as " + type);
});
</script>

</body>
</html>
