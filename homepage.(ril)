<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Click2Bite</title>

<link rel="stylesheet" href="design.css">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
body {
font-family: Arial;
margin: 0;
background-image: url("https://tse1.mm.bing.net/th/id/OIP.MXKW2_ioa94ry70NGKvysgHaFj?pid=Api&P=0&h=180");
background-size: cover;
background-repeat: no-repeat;
background-position: center;

}

/* NAV */
nav {
display: flex;
justify-content: space-between;
align-items: center;
padding: 15px 5%;
background: white;
box-shadow: 0 2px 5px rgba(0,0,0,0.1);

}

.logo {
font-weight: bold;
color: #8b0000;
}

.nav-links {
display: flex;
gap: 20px;
list-style: none;
}

.nav-links a {
text-decoration: none;
color: #333;
}

.btn-login {
background: #8b0000;
color: white;
padding: 5px 10px;
border-radius: 5px;
}

/* SECTION */
.section {
padding: 40px;
text-align: center;
}

.section-title {
color: #8b0000;
}

/* SEARCH */
#search {
width: 100%;
max-width: 400px;
padding: 10px;
margin: 20px auto;
display: block;
border-radius: 8px;
border: 1px solid #ccc;
}

/* GRID */
.canteen-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
gap: 20px;
}

/* CARD */
.canteen-card {
background: white;
border-radius: 15px;
overflow: hidden;
box-shadow: 0 5px 15px rgba(0,0,0,0.1);
transition: 0.3s;
}

.canteen-card:hover {
transform: translateY(-5px);
box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

/* IMAGE */
.canteen-card img {
width: 100%;
height: 150px;
object-fit: cover;
}

/* INFO */
.canteen-info {
padding: 15px;
text-align: left;
}

.location {
color: gray;
font-size: 0.9rem;
}

/* META */
.meta {
display: flex;
justify-content: space-between;
margin: 10px 0;
}

/* STATUS */
.status {
padding: 3px 8px;
border-radius: 5px;
font-size: 0.8rem;
}

.open {
background: green;
color: white;
}

.closed {
background: gray;
color: white;
}

/* BUTTON */
.cta-button {
width: 100%;
padding: 10px;
background: #8b0000;
color: white;
border: none;
border-radius: 8px;
cursor: pointer;
}

.cta-button:hover {
background: #a00000;
}

.disabled {
opacity: 0.5;
}

.disabled-btn {
background: gray;
cursor: not-allowed;
}

/* FOOTER */
footer {
text-align: center;
padding: 20px;
background: #222;
color: #aaa;
margin-top: 40px;
}
</style>
</head>

<body>

<!-- NAV -->
<nav>
<div class="logo">
<i class="fas fa-utensils"></i>
<span>Click2Bite</span>
</div>

<ul class="nav-links">
<li><a href="#">Home</a></li>
<li><a href="#">Canteens</a></li>
<li><a href="orders.html">My Orders</a></li>
<li><a href="indexxx.html" class="btn-login">Log Out</a></li>
</ul>
</nav>

<!-- HEADER -->
<section class="section">
<h2 class="section-title">Welcome to Click2Bite</h2>
<p>Order your favorite meals from the WMSU canteen quickly and easily.</p>
</section>

<!-- CANTEENS -->
<section class="section">

<h2 class="section-title">Canteens</h2>

<!-- SEARCH -->
<input type="text" id="search" placeholder="Search canteen..." onkeyup="searchCanteen()">

<div class="canteen-grid" id="canteenGrid">

<!-- CARD -->
<div class="canteen-card" data-name="jmjj food corner">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>JMJJ Food Corner</h3>
<p class="location">📍 Campus A</p>

<div class="meta">
<span class="rating">⭐ 4.5</span>
<span class="status open">OPEN</span>
</div>

<button onclick="openMenu('JMJJ food corner')" class="cta-button">Order</button>
</div>
</div>

<div class="canteen-card" data-name="crimson cafe">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>Crimson's Cafe</h3>
<p class="location">📍 Campus A</p>

<div class="meta">
<span class="rating">⭐ 4.7</span>
<span class="status open">OPEN</span>
</div>

<button onclick="openMenu('Crimson cafe')" class="cta-button">Order</button>
</div>
</div>

<div class="canteen-card" data-name="cups bento">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>Cups Bento</h3>
<p class="location">📍 Campus A</p>

<div class="meta">
<span class="rating">⭐ 4.3</span>
<span class="status open">OPEN</span>
</div>

<button onclick="openMenu('Cups bento')" class="cta-button">Order</button>
</div>
</div>

<div class="canteen-card" data-name="gemz kitchen">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>Gemz Kitchen</h3>
<p class="location">📍 Campus A</p>

<div class="meta">
<span class="rating">⭐ 4.6</span>
<span class="status open">OPEN</span>
</div>

<button onclick="openMenu('Gemz kitchen')" class="cta-button">Order</button>
</div>
</div>

<div class="canteen-card" data-name="al fresco">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>Al Fresco</h3>
<p class="location">📍 Campus B</p>

<div class="meta">
<span class="rating">⭐ 4.4</span>
<span class="status open">OPEN</span>
</div>

<button onclick="openMenu('Al fresco')" class="cta-button">Order</button>
</div>
</div>

<!-- CLOSED -->
<div class="canteen-card disabled" data-name="afy">
<img src="https://via.placeholder.com/300x150">
<div class="canteen-info">
<h3>AFY</h3>
<p class="location">📍 Campus B</p>

<div class="meta">
<span class="rating">⭐ 3.8</span>
<span class="status closed">CLOSED</span>
</div>

<button disabled class="cta-button disabled-btn">Unavailable</button>
</div>
</div>

</div>
</section>

<footer>
<p>© 2026 Click2Bite - WMSU</p>

<a href="admin-login.html" style="color:#aaa;">Admin Login</a>

</footer>

<!-- JS -->
<script>

// SEARCH FUNCTION
function searchCanteen(){
let input = document.getElementById("search").value.toLowerCase();
let cards = document.querySelectorAll(".canteen-card");

cards.forEach(card=>{
let name = card.getAttribute("data-name");

if(name.includes(input)){
card.style.display = "block";
}else{
card.style.display = "none";
}
});
}

// OPEN MENU
function openMenu(name){
localStorage.setItem("selectedCanteen", name);
window.location.href = "menu.html";
}

</script>

</body>
</html>
